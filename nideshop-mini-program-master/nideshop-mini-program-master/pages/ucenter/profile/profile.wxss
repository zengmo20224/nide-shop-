page{
  min-height: 100%;
  background: #f4f4f4;
}

.container{
  padding: 24rpx 30rpx;
}

.profile-card,
.form-panel{
  background: #fff;
}

.profile-card{
  height: 220rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.avatar{
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  background: #f4f4f4;
}

.avatar-btn{
  margin-left: 30rpx;
  width: 180rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 6rpx;
  background: #b4282d;
  color: #fff;
  font-size: 26rpx;
}

.form-panel{
  margin-top: 24rpx;
  padding: 0 28rpx 28rpx;
}

.form-title{
  height: 82rpx;
  line-height: 82rpx;
  font-size: 30rpx;
  color: #333;
  border-bottom: 1rpx solid #eee;
}

.form-row{
  min-height: 96rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.label{
  width: 150rpx;
  color: #666;
  font-size: 28rpx;
}

.readonly{
  flex: 1;
  color: #999;
  font-size: 28rpx;
}

.input{
  flex: 1;
  height: 86rpx;
  color: #333;
  font-size: 28rpx;
}

.submit-btn{
  margin-top: 28rpx;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  background: #b4282d;
  color: #fff;
  font-size: 30rpx;
}

.submit-btn.muted{
  background: #333;
}
