page{
  min-height: 100%;
  background: #f4f4f4;
}

.container{
  padding: 24rpx 30rpx;
}

.balance-card{
  height: 180rpx;
  padding: 32rpx;
  background: #333;
  color: #fff;
}

.balance-card .label{
  font-size: 26rpx;
  color: rgba(255,255,255,.72);
}

.balance-card .amount{
  margin-top: 18rpx;
  color: #fff;
  font-size: 52rpx;
  line-height: 60rpx;
}

.form-panel{
  margin-top: 24rpx;
  padding: 28rpx;
  background: #fff;
}

.form-title{
  margin-bottom: 20rpx;
  color: #333;
  font-size: 30rpx;
}

.amount-input{
  height: 88rpx;
  padding: 0 20rpx;
  background: #f4f4f4;
  font-size: 34rpx;
}

.quick-list{
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 24rpx;
}

.quick-item{
  width: 196rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border: 1rpx solid #d9d9d9;
  color: #333;
  font-size: 28rpx;
}

.submit-btn{
  margin-top: 40rpx;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  background: #b4282d;
  color: #fff;
  font-size: 30rpx;
}
