<view class="container">
  <view class="form-box">
    <view class="form-item">
      <input class="username" value="{{username}}" bindinput="bindUsernameInput" placeholder="账号，3-20 位" maxlength="20" auto-focus/>
      <image wx:if="{{username.length > 0}}" id="clear-username" class="clear" src="/static/images/clear_input.png" catchtap="clearInput"></image>
    </view>

    <view class="form-item">
      <input class="password" value="{{password}}" password bindinput="bindPasswordInput" placeholder="密码，不少于 6 位" maxlength="32"/>
      <image class="clear" id="clear-password" wx:if="{{password.length > 0}}" src="/static/images/clear_input.png" catchtap="clearInput"></image>
    </view>

    <view class="form-item">
      <input class="password" value="{{confirmPassword}}" password bindinput="bindConfirmPasswordInput" placeholder="确认密码" maxlength="32"/>
      <image class="clear" id="clear-confirm-password" wx:if="{{confirmPassword.length > 0}}" src="/static/images/clear_input.png" catchtap="clearInput"></image>
    </view>

    <view class="form-item">
      <input class="mobile" value="{{mobile}}" type="number" bindinput="bindMobileInput" placeholder="手机号，必填" maxlength="11"/>
      <image class="clear" id="clear-mobile" wx:if="{{mobile.length > 0}}" src="/static/images/clear_input.png" catchtap="clearInput"></image>
    </view>

    <button type="default" class="login-btn" loading="{{isSubmitting}}" disabled="{{isSubmitting}}" bindtap="startRegister">注册并登录</button>
  </view>
</view>
